<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>Memories AI</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script>tailwind.config={darkMode:'class',theme:{extend:{colors:{dark:{100:'#1a1a1e',200:'#121215',300:'#09090b'},zinc:{850:'#1c1c20'}}}}}</script>
    <style>
        [x-cloak]{display:none!important}
        .hide-scroll::-webkit-scrollbar{display:none}
        .card-bento{background:#121215;border:1px solid #1e1e24;border-radius:20px}
        .line-clamp-3{display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden}
        @keyframes fadeIn{from{opacity:0;transform:scale(.95)}to{opacity:1;transform:scale(1)}}
        @keyframes toastUp{from{opacity:0;transform:translate(-50%,10px)}to{opacity:1;transform:translate(-50%,0)}}
        .anim-fade{animation:fadeIn .2s ease-out}
        .toast-anim{animation:toastUp .3s ease-out}
    </style>
</head>
<body class="bg-black text-white font-sans antialiased">
<!-- Toast -->
<div x-show="toast.show" x-transition.duration.300ms class="fixed top-16 left-1/2 z-[9999] px-4 py-2 rounded-full text-sm font-medium toast-anim shadow-2xl"
     :class="toast.type==='error'?'bg-red-500/90 text-white':'bg-zinc-800/90 text-white border border-zinc-700'" x-text="toast.text"></div>

<!-- Moment Edit Modal (rename label) -->
<div x-show="momentEdit.show" x-cloak class="fixed inset-0 z-[75] flex items-end sm:items-center justify-center p-4 bg-black/60 backdrop-blur-sm" @keydown.escape="momentEdit.show=false">
    <div class="bg-[#1c1c20] border border-zinc-800 w-full max-w-sm rounded-2xl p-6 anim-fade">
        <h3 class="text-base font-bold mb-3" x-text="''+momentEdit.action.charAt(0).toUpperCase()+momentEdit.action.slice(1)+' Moment'"></h3>
        <input x-model="momentEdit.input" @keydown.enter="doMomentEdit()" type="text" class="w-full bg-black border border-zinc-700 rounded-xl py-3 px-4 mb-4 outline-none focus:border-blue-500" autofocus>
        <div class="flex gap-2">
            <button @click="momentEdit.show=false" class="flex-1 bg-zinc-700 hover:bg-zinc-600 text-sm font-medium py-2.5 rounded-xl">Cancel</button>
            <button @click="doMomentEdit()" class="flex-1 bg-blue-500 hover:bg-blue-600 text-white text-sm font-semibold py-2.5 rounded-xl">Save</button>
        </div>
    </div>
</div>

<!-- Add Moment Modal -->
<!-- Add Moment Modal -->
<div x-show="rnOpen" x-cloak class="fixed inset-0 z-[75] flex items-end sm:items-center justify-center p-4 bg-black/60 backdrop-blur-sm" @keydown.escape.window="rnOpen=false">
    <div class="bg-[#1c1c20] border border-zinc-800 w-full max-w-sm rounded-2xl p-6 anim-fade" @click.away="rnOpen=false">
        <h3 class="text-base font-bold mb-3">Rename Person</h3>
        <input x-model="rnInput" @keydown.enter="doRename()" type="text" class="w-full bg-black border border-zinc-700 rounded-xl py-3 px-4 mb-4 outline-none focus:border-blue-500" placeholder="Enter new name..." x-ref="rnField">
        <div class="flex gap-2">
            <button @click="rnOpen=false" class="flex-1 bg-zinc-700 hover:bg-zinc-600 text-sm font-medium py-2.5 rounded-xl">Cancel</button>
            <button @click="doRename()" class="flex-1 bg-blue-500 hover:bg-blue-600 text-white text-sm font-semibold py-2.5 rounded-xl">Save</button>
        </div>
    </div>
</div>

<!-- Move Photo Modal -->
<div x-show="lbMoveShow" x-cloak class="fixed inset-0 z-[150] flex items-end sm:items-center justify-center p-4 bg-black/60 backdrop-blur-sm" @keydown.escape.window="lbMoveShow=false">
    <div class="bg-[#1c1c20] border border-zinc-800 w-full max-w-sm rounded-2xl p-5 anim-fade" @click.away="lbMoveShow=false">
        <h3 class="text-base font-bold mb-3">Move Photo to Folder</h3>
        <div class="space-y-2 mb-4">
            <button @click="doMovePhoto('data/input/photos')" class="w-full text-left px-4 py-3 bg-zinc-800 hover:bg-zinc-700 rounded-xl text-sm flex items-center gap-3"><i data-lucide="image" class="w-4 h-4 text-zinc-500"></i><span>Photos (general)</span></button>
            <button @click="doMovePhoto('data/input/family')" class="w-full text-left px-4 py-3 bg-zinc-800 hover:bg-zinc-700 rounded-xl text-sm flex items-center gap-3"><i data-lucide="users" class="w-4 h-4 text-blue-400"></i><span>Family</span></button>
            <button @click="doMovePhoto('data/input/travel')" class="w-full text-left px-4 py-3 bg-zinc-800 hover:bg-zinc-700 rounded-xl text-sm flex items-center gap-3"><i data-lucide="map-pin" class="w-4 h-4 text-green-400"></i><span>Travel</span></button>
            <button @click="doMovePhoto('data/input/events')" class="w-full text-left px-4 py-3 bg-zinc-800 hover:bg-zinc-700 rounded-xl text-sm flex items-center gap-3"><i data-lucide="calendar" class="w-4 h-4 text-purple-400"></i><span>Events</span></button>
        </div>
        <button @click="lbMoveShow=false" class="w-full bg-zinc-700 hover:bg-zinc-600 text-sm font-medium py-2.5 rounded-xl">Cancel</button>
    </div>
</div>

<!-- Delete Photo Modal -->
<div x-show="lbDeleteShow" x-cloak class="fixed inset-0 z-[75] flex items-end sm:items-center justify-center p-4 bg-black/60 backdrop-blur-sm" @keydown.escape="lbDeleteShow=false">
    <div class="bg-[#1c1c20] border border-zinc-800 w-full max-w-sm rounded-2xl p-6 anim-fade" @click.away="lbDeleteShow=false">
        <h3 class="text-base font-bold mb-3 text-red-400">Delete Photo?</h3>
        <p class="text-sm text-zinc-400 mb-5 leading-relaxed">This will permanently delete <span class="text-zinc-200" x-text="lbPhoto?lbPhoto.file_path.split('/').pop():''"></span></p>
        <div class="flex gap-2">
            <button @click="lbDeleteShow=false" class="flex-1 bg-zinc-700 hover:bg-zinc-600 text-sm font-medium py-2.5 rounded-xl">Cancel</button>
            <button @click="doDeletePhoto()" class="flex-1 bg-red-500 hover:bg-red-600 text-white text-sm font-semibold py-2.5 rounded-xl">Delete</button>
        </div>
    </div>
</div>

<!-- Add Moment Modal -->
<div x-show="addMomentOpen" x-cloak class="fixed inset-0 z-[75] flex items-end sm:items-center justify-center p-4 bg-black/60 backdrop-blur-sm" @keydown.escape="addMomentOpen=false">
    <div class="bg-[#1c1c20] border border-zinc-800 w-full max-w-sm rounded-2xl p-6 anim-fade" @click.away="addMomentOpen=false">
        <h3 class="text-base font-bold mb-3">Create New Moment</h3>
        <p class="text-xs text-zinc-500 mb-3 leading-relaxed">Group your photos together. AI will label them automatically if you leave it blank.</p>
        <input x-model="newMomentLabel" @keydown.enter="doAddMoment()" type="text" class="w-full bg-black border border-zinc-700 rounded-xl py-3 px-4 mb-4 outline-none focus:border-blue-500" placeholder="e.g. Beach Day, Christmas 2025" x-ref="momentField">
        <p class="text-xs text-zinc-600 mb-4">Recent photos will be included. You can also just let AI auto-generate.</p>
        <div class="flex gap-2">
            <button @click="addMomentOpen=false" class="flex-1 bg-zinc-700 hover:bg-zinc-600 text-sm font-medium py-2.5 rounded-xl">Cancel</button>
            <button @click="doAddMoment()" class="flex-1 bg-blue-500 hover:bg-blue-600 text-white text-sm font-semibold py-2.5 rounded-xl">Create</button>
        </div>
    </div>
</div>

<!-- Confirm Modal -->
<div x-show="confirm.show" x-cloak class="fixed inset-0 z-[80] flex items-center justify-center p-4 bg-black/70 backdrop-blur-sm" @keydown.escape="confirm.show=false">
    <div class="bg-[#1c1c20] border border-zinc-800 w-full max-w-sm rounded-2xl p-6 anim-fade">
        <h3 class="text-base font-bold mb-3" x-text="confirm.title||'Confirm'"></h3>
        <p class="text-sm text-zinc-400 mb-5 leading-relaxed" x-text="confirm.message"></p>
        <div class="flex gap-2">
            <button @click="confirm.show=false" class="flex-1 bg-zinc-700 hover:bg-zinc-600 text-sm font-medium py-2.5 rounded-xl">Cancel</button>
            <button @click="confirm.onConfirm();confirm.show=false" class="flex-1 bg-red-500 hover:bg-red-600 text-white text-sm font-semibold py-2.5 rounded-xl" x-text="confirm.okText||'Confirm'"></button>
        </div>
    </div>
</div>

<!-- Moment Edit Modal (rename label) -->

<div x-data="app()" x-init="init()" class="max-w-2xl mx-auto min-h-screen relative" style="padding-bottom:80px">

<!-- ===== DISCOVER ===== -->
<div x-show="tab==='home'">
    <header class="px-6 pt-14 pb-4 flex items-end justify-between sticky top-0 z-20" style="background:linear-gradient(to bottom,#000 60%,transparent)">
        <div><h1 class="text-2xl font-bold tracking-tight">Discover</h1><p class="text-zinc-500 text-sm mt-0.5">Sorted by face. Understood by AI.</p></div>
        <button @click="refreshAll()" class="bg-zinc-800/50 p-2 rounded-full hover:bg-zinc-700"><i data-lucide="refresh-cw" class="w-5 h-5 text-zinc-400" :class="loading?'animate-spin':''"></i></button>
    </header>
    <!-- Insights -->
    <div class="px-4 mb-6 grid grid-cols-2 gap-3">
        <template x-for="(ins,i) in insights" :key="i">
            <div @click="expIns=expIns===i?null:i" class="card-bento p-4 cursor-pointer" style="transition:transform .15s" @mousedown="$el.style.transform='scale(0.95)'" @mouseup="$el.style.transform=''" @mouseleave="$el.style.transform=''">
                <i :data-lucide="ins.icon==='🏆'?'trophy':ins.icon==='📸'?'camera':ins.icon==='🌍'?'globe-2':'sparkles'" class="w-5 h-5 text-blue-400 mb-2"></i>
                <p class="text-xs text-zinc-400 leading-relaxed whitespace-pre-wrap" :class="expIns===i?'':'line-clamp-3'" x-text="ins.message"></p>
                <span x-show="ins.message.length>50&&expIns!==i" class="text-[10px] text-blue-400 mt-1 inline-block">Tap to read</span>
            </div>
        </template>
    </div>
    <!-- Top Rated -->
    <div x-show="topPhotos.length" class="px-4 mb-6">
        <div class="flex justify-between items-center mb-3"><h2 class="text-lg font-semibold">Top Rated</h2><span class="text-xs text-zinc-500" x-text="topPhotos.length+' photos'"></span></div>
        <div class="flex gap-3 overflow-x-auto hide-scroll pb-2" style="-webkit-mask-image:linear-gradient(to right,black 85%,transparent 100%)">
            <template x-for="img in topPhotos" :key="img.file_path">
                <div @click="lightboxOpenFromList(getPhotoIdx(img))" class="flex-shrink-0 w-32 h-48 rounded-2xl overflow-hidden relative border border-zinc-800/50 cursor-pointer" style="transition:transform .15s" @mousedown="$el.style.transform='scale(0.95)'" @mouseup="$el.style.transform=''" @mouseleave="$el.style.transform=''">
                    <img :src="imgThumb(img)" class="w-full h-full object-cover opacity-90 hover:opacity-100" loading="lazy">
                    <div class="absolute top-2 right-2 bg-green-500/90 text-[10px] font-bold px-1.5 py-0.5 rounded-md" x-text="(img.quality_score||0).toFixed(1)"></div>
                </div>
            </template>
        </div>
    </div>
    <!-- People -->
    <div class="px-4 mb-8">
        <h2 class="text-lg font-semibold mb-3">Your People</h2>
        <div class="grid grid-cols-6 gap-3">
            <template x-for="p in people" :key="p.id">
                <button @click="viewPersonGallery(p)" class="flex flex-col items-center gap-1 group" style="transition:transform .15s" @mousedown="$el.style.transform='scale(0.95)'" @mouseup="$el.style.transform=''" @mouseleave="$el.style.transform=''">
                        <div class="w-12 h-12 rounded-full overflow-hidden border-2 border-zinc-800 group-hover:border-blue-500 transition-colors bg-zinc-800">
                            <img :src="p.avatarUrl" class="w-full h-full object-cover" alt="" @error="$el.style.display='none';$el.nextElementSibling.style.display='flex'" :style="p.avatarUrl?'':'display:none'">
                            <span class="w-full h-full bg-zinc-800 flex items-center justify-center text-zinc-500 font-bold text-[10px]" x-text="(p.display||'?').substring(0,2)" :style="p.avatarUrl?'display:none':''"></span>
                        </div>
                    <span class="text-[9px] text-zinc-400 truncate w-12 text-center" x-text="p.display"></span>
                </button>
            </template>
        </div>
    </div>
</div>

<!-- ===== MOMENTS ===== -->
<div x-show="tab==='moments'" x-cloak>
    <div class="px-6 pt-14 pb-4 border-b border-zinc-800/50 sticky top-0 z-20" style="background:rgba(0,0,0,0.9);backdrop-filter:blur(16px)">
        <div class="flex items-end justify-between gap-2">
            <div><h1 class="text-2xl font-bold tracking-tight">Moments</h1><p class="text-zinc-500 text-sm mt-0.5" x-show="moments.length" x-text="moments.length+' moments found'"></p></div>
            <button @click="confirmAction('Regenerate moments from scratch using current photos? This will replace all current moments.','regenerateMoments')" class="bg-zinc-800/50 px-3 py-1.5 rounded-lg text-xs text-zinc-400 hover:text-white flex items-center gap-1"><i data-lucide="refresh-ccw" class="w-3.5 h-3.5"></i>Refresh</button>
            <button @click="addMomentOpen=true;newMomentLabel='';$nextTick(()=>{if($refs.momentField)$refs.momentField.focus()})" class="bg-blue-500/20 px-3 py-1.5 rounded-lg text-xs text-blue-400 hover:text-blue-300 flex items-center gap-1"><i data-lucide="plus" class="w-3.5 h-3.5"></i>New</button>
        </div>
    </div>
    <div class="px-4 pt-4 pb-24 space-y-6">
        <template x-for="m in moments" :key="m.id">
            <div class="card-bento overflow-hidden relative group">
                <!-- Long press context menu -->
                <div @click="openMomentGallery(m)" class="cursor-pointer relative" style="transition:transform .15s" @mousedown="mgCtxStart($event,m,'img')" @mouseup="mgCtxEnd()" @mouseleave="mgCtxEnd()">
                    <img :src="imgThumb(m)" class="w-full h-52 object-cover" loading="lazy">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent"></div>
                    <div class="absolute bottom-3 left-4 right-4 flex justify-between items-end">
                        <div><h3 class="capitalize font-semibold text-lg text-white" x-text="m.label"></h3><p class="text-xs text-zinc-300" x-text="getMomentDateRange(m)"></p></div>
                        <span class="bg-blue-500/20 text-blue-300 text-xs font-semibold px-2.5 py-1 rounded-full" x-text="m.count+' photos'"></span>
                    </div>
                </div>
                <!-- Edit overlay button (top-right) -->
                <button @click.stop="showMomentMenu(m)" class="absolute top-2 right-2 p-1.5 bg-black/50 rounded-full opacity-60 hover:opacity-100"><i data-lucide="more-vertical" class="w-4 h-4"></i></button>
                <!-- Context Menu -->
                <div x-show="m.__menu" class="absolute top-10 right-2 z-40 bg-zinc-800 border border-zinc-700 rounded-xl shadow-2xl overflow-hidden min-w-[180px]" @click.away="m.__menu=false">
                    <button @click="editMomentLabel(m)" class="w-full px-4 py-2.5 text-sm text-left hover:bg-zinc-700 flex items-center gap-2.5"><i data-lucide="pencil" class="w-4 h-4 text-zinc-400"></i><span>Rename</span></button>
                    <button @click="openMomentGallery(m);m.__menu=false" class="w-full px-4 py-2.5 text-sm text-left hover:bg-zinc-700 flex items-center gap-2.5"><i data-lucide="grid-3x3" class="w-4 h-4 text-zinc-400"></i><span>View photos</span></button>
                    <button @click="confirmAction('Delete this moment permanently? Photos will not be deleted.','deleteMoment::'+m.id)" class="w-full px-4 py-2.5 text-sm text-left text-red-400 hover:bg-zinc-700 flex items-center gap-2.5"><i data-lucide="trash-2" class="w-4 h-4"></i><span>Delete</span></button>
                </div>
            </div>
        </template>
        <div x-show="!moments.length&&!loading" class="text-center text-zinc-600 py-24">
            <p class="text-lg mb-2">No moments yet</p>
            <p class="text-sm">Upload more photos or refresh to regenerate</p>
        </div>
    </div>
</div>

<!-- ===== PEOPLE ===== -->
<div x-show="tab==='people'" x-cloak>
    <div class="px-6 pt-14 pb-4 sticky top-0 z-20" style="background:rgba(0,0,0,0.9);backdrop-filter:blur(16px)">
        <div class="relative mb-3">
            <input x-model="searchQ" @input.debounce.400ms="doSearch()" type="text" placeholder="Search faces, objects, captions..." class="w-full bg-zinc-900 border border-zinc-800 rounded-xl py-2.5 px-4 pl-10 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500/50 outline-none">
            <i data-lucide="search" class="w-4 h-4 text-zinc-500 absolute left-3.5 top-1/2 -translate-y-1/2"></i>
            <button x-show="searchQ" @click="searchQ='';searchRes=null" class="absolute right-3 top-1/2 -translate-y-1/2 text-zinc-500 hover:text-white"><i data-lucide="x" class="w-4 h-4"></i></button>
        </div>
        <h1 class="text-xl font-bold" x-show="!searchQ">People <span class="text-zinc-500 text-sm font-normal" x-text="people.length"></span></h1>
        <h1 class="text-lg font-semibold" x-show="searchQ" x-text="'Results'"></h1>
    </div>
    <template x-if="searchRes!==null">
        <div class="px-4 pt-2 pb-24">
            <p class="text-xs text-zinc-500 mb-2" x-text="(searchRes||[]).length+' photos found'"></p>
            <div class="columns-3 gap-2">
                <template x-for="r in (searchRes||[])" :key="r.image_path">
                    <div @click="lightboxOpenFromList(findPhotoIdx(r.image_path))" class="mb-2 break-inside-avoid rounded-xl overflow-hidden cursor-pointer" style="transition:transform .15s" @mousedown="$el.style.transform='scale(0.95)'" @mouseup="$el.style.transform=''" @mouseleave="$el.style.transform=''">
                        <img :src="'/images/'+r.image_path.split('/').pop()" class="w-full h-auto object-cover" loading="lazy">
                    </div>
                </template>
            </div>
            <div x-show="!searchRes.length" class="text-center text-zinc-600 py-20 text-sm">No results for your query</div>
        </div>
    </template>
    <div x-show="!searchQ&&searchRes===null" class="px-4 pt-2 pb-24">
        <div class="grid grid-cols-2 gap-3">
            <template x-for="p in people" :key="p.id">
                <div class="card-bento p-4 flex flex-col items-center text-center relative">
                    <!-- Edit menu -->
                    <button @click.stop="p.__menu=!p.__menu" class="absolute top-2 right-2 p-1.5 bg-black/30 rounded-full opacity-50 hover:opacity-100"><i data-lucide="more-vertical" class="w-3.5 h-3.5"></i></button>
                    <div x-show="p.__menu" class="absolute top-9 right-2 z-30 bg-zinc-800 border border-zinc-700 rounded-xl shadow-2xl overflow-hidden min-w-[150px]" @click.away="p.__menu=false">
                        <button @click.stop="openRename(p);p.__menu=false" class="w-full px-3 py-2 text-sm text-left hover:bg-zinc-700 flex items-center gap-2"><i data-lucide="pencil" class="w-3.5 h-3.5 text-zinc-400"></i><span>Rename</span></button>
                        <button @click.stop="confirmAction('Merge '+p.display+' into... (select target in next step)','mergeInit::'+p.id)" class="w-full px-3 py-2 text-sm text-left hover:bg-zinc-700 flex items-center gap-2"><i data-lucide="git-merge" class="w-3.5 h-3.5 text-blue-400"></i><span>Merge</span></button>
                        <button @click.stop="confirmAction('Delete '+p.display+'? Photos keep their faces but this person will be removed.','deletePerson::'+p.id)" class="w-full px-3 py-2 text-sm text-left text-red-400 hover:bg-zinc-700 flex items-center gap-2"><i data-lucide="trash-2" class="w-3.5 h-3.5"></i><span>Delete</span></button>
                    </div>
                        <div class="w-20 h-20 rounded-full overflow-hidden border-2 border-zinc-700 mb-3 bg-zinc-800">
                            <img :src="p.avatarUrl" class="w-full h-full object-cover" alt="" @error="$el.style.display='none';$el.nextElementSibling.style.display='flex'" :style="p.avatarUrl?'':'display:none'">
                            <span class="w-full h-full flex items-center justify-center text-zinc-500 font-bold text-2xl" x-text="(p.display||'?').substring(0,2)" :style="p.avatarUrl?'display:none':''"></span>
                        </div>
                    <h3 class="font-semibold truncate w-full" x-text="p.display"></h3>
                    <p class="text-xs text-zinc-500 mt-0.5" x-text="p.face_count+' photos'"></p>
                    <div class="flex gap-2 mt-4 w-full">
                        <button @click.stop="viewTimeline(p)" class="flex-1 bg-zinc-800 hover:bg-zinc-700 text-xs font-semibold py-2 rounded-lg transition-colors">Timeline</button>
                        <button @click.stop="viewPersonGallery(p)" class="flex-1 bg-zinc-800 hover:bg-zinc-700 text-xs font-semibold py-2 rounded-lg transition-colors">Gallery</button>
                    </div>
                </div>
            </template>
        </div>
    </div>
</div>

<!-- ===== SETTINGS ===== -->
<div x-show="tab==='settings'" x-cloak>
    <div class="px-6 pt-14 pb-4 sticky top-0 z-20 border-b border-zinc-800/50" style="background:rgba(0,0,0,0.9);backdrop-filter:blur(16px)">
        <h1 class="text-2xl font-bold tracking-tight">Settings</h1>
    </div>
    <div class="px-4 pt-4 pb-24 space-y-4">
        <!-- Moments -->
        <div class="card-bento overflow-hidden">
            <div class="px-4 py-3 border-b border-zinc-800/50"><h3 class="text-sm font-semibold text-zinc-300">Moments</h3></div>
            <button @click="confirmAction('Regenerate all moments from scratch?','regenerateMoments')" class="w-full px-4 py-3 text-left hover:bg-zinc-800/30 flex justify-between items-center">
                <span class="text-sm"><i data-lucide="refresh-ccw" class="w-4 h-4 inline mr-2 text-blue-400"></i>Regenerate moments</span>
                <i data-lucide="chevron-right" class="w-4 h-4 text-zinc-500"></i></button>
        </div>
        <!-- Data -->
        <div class="card-bento overflow-hidden">
            <div class="px-4 py-3 border-b border-zinc-800/50"><h3 class="text-sm font-semibold text-zinc-300">Data & Cache</h3></div>
            <button @click="confirmAction('Delete all cached face thumbnails?','clearFaces')" class="w-full px-4 py-3 text-left hover:bg-zinc-800/30 flex justify-between items-center">
                <span class="text-sm text-orange-400"><i data-lucide="trash-2" class="w-4 h-4 inline mr-2"></i>Clear face cache</span>
                <i data-lucide="chevron-right" class="w-4 h-4 text-zinc-500"></i></button>
        </div>
        <!-- Merge People -->
        <div class="card-bento overflow-hidden">
            <div class="px-4 py-3 border-b border-zinc-800/50"><h3 class="text-sm font-semibold text-zinc-300">Merge People</h3></div>
            <p class="px-4 py-2 text-xs text-zinc-500">Tap the "⋮" menu on any person card in the People tab and select "Merge"</p>
        </div>
        <!-- About -->
        <div class="card-bento p-4">
            <p class="text-xs text-zinc-500 leading-relaxed">Memories AI — v0.9<br>FastAPI · CLIP · BLIP · InsightFace<br>Running on local hardware</p>
        </div>
    </div>
</div>

<!-- ===== LIGHTBOX ===== -->
<div x-show="lbOpen" x-cloak class="fixed inset-0 z-[70] bg-black flex flex-col" @keydown.escape.window="lbOpen=false;lbDetail=false" @keydown.arrow-left.window="lbPrev()" @keydown.arrow-right.window="lbNext()">
    <div class="absolute inset-x-0 top-0 z-10 flex items-center justify-between p-4 pt-12" style="background:linear-gradient(to bottom,rgba(0,0,0,0.8),transparent)">
        <button @click="lbOpen=false" class="p-2 bg-zinc-800/80 rounded-full"><i data-lucide="x" class="w-5 h-5"></i></button>
        <span class="text-sm text-zinc-400" x-show="lbPhotos.length>1" x-text="(lbIdx+1)+' / '+lbPhotos.length"></span>
        <div class="relative">
            <button @click.stop="lbMenuOpen=!lbMenuOpen" class="p-2 bg-zinc-800/80 rounded-full"><i data-lucide="more-vertical" class="w-5 h-5"></i></button>
            <div x-show="lbMenuOpen" x-transition class="absolute right-0 top-full mt-1 bg-zinc-900 border border-zinc-700 rounded-xl overflow-hidden shadow-2xl min-w-[160px] z-[80]">
                <button @click.stop="lbEditCaption();lbMenuOpen=false" class="w-full px-4 py-3 text-left text-sm hover:bg-zinc-800 flex items-center gap-2"><i data-lucide="edit-3" class="w-4 h-4 text-zinc-400"></i><span>Edit Caption</span></button>
                <button @click.stop="lbMovePhoto();lbMenuOpen=false" class="w-full px-4 py-3 text-left text-sm hover:bg-zinc-800 flex items-center gap-2"><i data-lucide="folder" class="w-4 h-4 text-zinc-400"></i><span>Move</span></button>
                <button @click.stop="lbDeletePhoto();lbMenuOpen=false" class="w-full px-4 py-3 text-left text-sm text-red-400 hover:bg-zinc-800 flex items-center gap-2"><i data-lucide="trash-2" class="w-4 h-4"></i><span>Delete</span></button>
            </div>
        </div>
    </div>
    <div class="flex-1 flex items-center justify-center relative overflow-hidden select-none" @touchstart="lbST=$event.changedTouches[0].clientX" @touchend="lbSwipe($event)" @click.self="lbDetail=!lbDetail;lbMenuOpen=false">
        <img :src="lbCurUrl" class="max-w-full max-h-full object-contain">
        <button x-show="lbIdx>0" @click.stop="lbPrev()" class="absolute left-2 top-1/2 -translate-y-1/2 p-2.5 bg-black/50 rounded-full"><i data-lucide="chevron-left" class="w-6 h-6"></i></button>
        <button x-show="lbIdx<lbPhotos.length-1" @click.stop="lbNext()" class="absolute right-2 top-1/2 -translate-y-1/2 p-2.5 bg-black/50 rounded-full"><i data-lucide="chevron-right" class="w-6 h-6"></i></button>
    </div>
    <div x-show="lbDetail" class="bg-zinc-900/95 border-t border-zinc-800 p-4 pb-24 overflow-y-auto" style="max-height:40vh">
        <template x-if="lbPhoto">
            <div>
                <!-- Inline caption edit -->
                <div x-show="lbCaptionEdit" class="mb-3">
                    <textarea x-model="lbCaption" class="w-full bg-black border border-zinc-700 rounded-lg py-2 px-3 text-sm outline-none focus:border-blue-500" rows="2" placeholder="Add a caption..."></textarea>
                    <div class="flex gap-2 mt-2">
                        <button @click="lbSaveCaption()" class="px-3 py-1 bg-blue-500 rounded-lg text-sm font-medium">Save</button>
                        <button @click="lbCaptionEdit=false" class="px-3 py-1 bg-zinc-700 rounded-lg text-sm">Cancel</button>
                    </div>
                </div>
                <div class="flex items-start gap-2 mb-3">
                    <p class="text-sm text-zinc-300 leading-relaxed whitespace-pre-wrap flex-1" x-text="lbPhoto.caption||'No caption'"></p>
                    <button @click="lbCaptionEdit=true;lbCaption=lbPhoto.caption||''" class="p-1 text-zinc-500 hover:text-zinc-300"><i data-lucide="edit-2" class="w-3.5 h-3.5"></i></button>
                </div>
                <div class="flex flex-wrap gap-x-4 gap-y-1 text-xs text-zinc-500">
                    <span x-text="lbPhoto.analyzed_at?fmtDate(lbPhoto.analyzed_at):'Unknown'"></span>
                    <span class="text-yellow-500" x-show="lbPhoto.quality_score" x-text="'★ '+(lbPhoto.quality_score||0).toFixed(1)"></span>
                    <span class="bg-blue-500/10 text-blue-400 px-2 py-0.5 rounded-full" x-text="lbPhoto.file_path?.split('/').pop()"></span>
                </div>
                <div class="flex gap-2 mt-3 flex-wrap" x-show="lbPhotoPeople.length">
                    <template x-for="pp in lbPhotoPeople" :key="pp.id">
                        <span class="text-xs bg-zinc-800 px-2 py-1 rounded-full text-zinc-300 flex items-center gap-1.5"><img :src="pp.avatarUrl" class="w-4 h-4 rounded-full object-cover"><span x-text="pp.display"></span></span>
                    </template>
                </div>
                <!-- Move / Delete buttons -->
                <div class="flex gap-2 mt-4">
                    <button @click="lbMovePhoto()" class="flex items-center gap-1.5 px-3 py-1.5 bg-zinc-800 hover:bg-zinc-700 rounded-lg text-xs"><i data-lucide="folder" class="w-3.5 h-3.5"></i><span>Move</span></button>
                    <button @click="lbDeletePhoto()" class="flex items-center gap-1.5 px-3 py-1.5 bg-red-900/30 hover:bg-red-900/50 text-red-400 rounded-lg text-xs"><i data-lucide="trash-2" class="w-3.5 h-3.5"></i><span>Delete</span></button>
                </div>
            </div>
        </template>
    </div>
    <div x-show="!lbDetail" class="absolute bottom-6 inset-x-0 text-center text-[10px] text-zinc-600">Tap for details · Swipe to navigate</div>
</div>

<!-- ===== PERSON GALLERY ===== -->
<div x-show="pgOpen" x-cloak class="fixed inset-0 z-[60] bg-black overflow-y-auto pb-20" @keydown.escape.window="pgOpen=false">
    <div class="sticky top-0 z-10 px-4 pt-14 pb-3 flex items-center gap-3" style="background:rgba(0,0,0,0.9);backdrop-filter:blur(16px);border-bottom:1px solid rgba(63,63,70,0.25)">
        <button @click="pgOpen=false" class="p-2 bg-zinc-800 rounded-full"><i data-lucide="arrow-left" class="w-5 h-5"></i></button>
        <div><h2 class="text-lg font-bold" x-text="pgPerson?.display||''"></h2><p class="text-xs text-zinc-500" x-text="pgPhotos.length+' photos'"></p></div>
    </div>
    <div class="px-2 pt-3 grid grid-cols-3 gap-1.5">
        <template x-for="(ph,i) in pgPhotos" :key="i">
            <div @click="lbFromPhotos(pgPhotos,i)" class="aspect-square rounded-lg overflow-hidden cursor-pointer" style="transition:transform .12s" @mousedown="$el.style.transform='scale(0.95)'" @mouseup="$el.style.transform=''" @mouseleave="$el.style.transform=''">
                <img :src="imgThumb(ph)" class="w-full h-full object-cover" loading="lazy">
            </div>
        </template>
        <div x-show="!pgPhotos.length" class="col-span-3 text-center text-zinc-600 py-20 text-sm">No photos found for this person</div>
    </div>
</div>

<!-- ===== MOMENT GALLERY (with edit mode) ===== -->
<div x-show="mgOpen" x-cloak class="fixed inset-0 z-[60] bg-black overflow-y-auto pb-20" @keydown.escape.window="mgOpen=false;mgEdit=false">
    <div class="sticky top-0 z-10 px-4 pt-14 pb-3 flex items-center justify-between" style="background:rgba(0,0,0,0.9);backdrop-filter:blur(16px);border-bottom:1px solid rgba(63,63,70,0.25)">
        <div class="flex items-center gap-3">
            <button @click="mgOpen=false;mgEdit=false" class="p-2 bg-zinc-800 rounded-full"><i data-lucide="arrow-left" class="w-5 h-5"></i></button>
            <div><h2 class="text-lg font-bold capitalize" x-text="mgMoment?.label"></h2><p class="text-xs text-zinc-500" x-text="mgPhotos.length+' photos'"></p></div>
        </div>
        <button @click="mgEdit=!mgEdit" class="p-2 bg-zinc-800 rounded-full"><i data-lucide="edit" class="w-4 h-4" :style="mgEdit?'color:#3B82F6':''"></i></button>
    </div>
    <div class="px-2 pt-3 grid grid-cols-3 gap-1.5">
        <template x-for="(ph,i) in mgPhotos" :key="i">
            <div @click.stop="mgEdit?null:lbFromPhotos(mgPhotos,i)" class="aspect-square rounded-lg overflow-hidden relative cursor-pointer" :style="mgEdit?'opacity:0.6':''" @mousedown="$el.style.transform='scale(0.95)'" @mouseup="$el.style.transform=''" @mouseleave="$el.style.transform=''">
                <img :src="imgThumb(ph)" class="w-full h-full object-cover transition-opacity" loading="lazy" :style="mgEdit?'filter:brightness(0.4)':''">
                <template x-if="mgEdit">
                    <div class="absolute inset-0 flex flex-col items-center justify-center gap-1.5">
                        <button @click.stop="setMomentCover(i)" class="p-2 bg-blue-500/80 rounded-full"><i data-lucide="image" class="w-4 h-4 text-white"></i></button>
                        <span class="text-[10px] text-zinc-300">Cover</span>
                        <button @click.stop="removeMomentPhoto(i)" class="p-2 bg-red-500/80 rounded-full"><i data-lucide="trash-2" class="w-4 h-4 text-white"></i></button>
                        <span class="text-[10px] text-zinc-300">Remove</span>
                    </div>
                </template>
            </div>
        </template>
        <div x-show="mgEdit" class="col-span-3">
            <button @click="mgEdit=false" class="mx-auto block bg-blue-500 text-white text-sm font-semibold px-4 py-2 rounded-lg mt-2">Done Editing</button>
        </div>
    </div>
</div>

<!-- ===== TIMELINE ===== -->
<div x-show="tlOpen" x-cloak class="fixed inset-0 z-[60] bg-black" style="transition:transform .3s" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="translate-y-full" x-transition:enter-end="translate-y-0" x-transition:leave="transition ease-in" x-transition:leave-start="translate-y-0" x-transition:leave-end="translate-y-full">
    <div class="flex items-center gap-3 p-4 pt-14" style="background:linear-gradient(to bottom,rgba(0,0,0,0.9),transparent);position:sticky;top:0;z-index:5">
        <button @click="tlOpen=false" class="p-2 bg-zinc-800 rounded-full"><i data-lucide="x" class="w-5 h-5"></i></button>
        <h2 class="text-lg font-bold" x-text="'Timeline · '+(tlPerson?.display||'')"></h2>
    </div>
    <div class="flex overflow-x-auto hide-scroll gap-3 px-3 pb-6 snap-x snap-mandatory" style="height:calc(100vh - 80px);align-items:center">
        <template x-for="ph in tlPhotos" :key="ph.file_path">
            <div @click="lbFromPhotos(tlPhotos,tlPhotos.indexOf(ph))" class="snap-center flex-shrink-0 w-72 bg-zinc-900 rounded-2xl overflow-hidden border border-zinc-800/50 relative cursor-pointer">
                <img :src="imgThumb(ph)" class="w-full h-72 object-cover" loading="lazy">
                <div class="absolute bottom-0 inset-x-0 p-5" style="background:linear-gradient(to top,rgba(0,0,0,0.9),transparent)">
                    <p class="text-[10px] text-blue-400 font-bold mb-0.5 uppercase" x-text="ph.analyzed_at?fmtDate(ph.analyzed_at):''"></p>
                    <p class="text-xs text-zinc-300 line-clamp-3" x-text="ph.caption||'No caption'"></p>
                </div>
            </div>
        </template>
        <div x-show="!tlPhotos.length" class="text-center text-zinc-600 text-sm py-20 flex-shrink-0 w-72">No timeline photos</div>
    </div>
</div>

<!-- ===== UPLOAD FAB ===== -->
<label class="fixed bottom-24 right-4 z-50 bg-blue-500 w-12 h-12 rounded-full flex items-center justify-center shadow-xl shadow-blue-500/20 hover:scale-110 transition-transform cursor-pointer active:scale-90">
    <i data-lucide="plus" class="w-6 h-6 text-white"></i>
    <input type="file" class="hidden" accept="image/*" multiple @change="handleUpload($event)">
</label>

<!-- Upload Progress -->
<div x-show="upProg>0&&upProg<100" class="fixed bottom-28 left-4 right-4 z-50 bg-zinc-800/90 border border-zinc-700/50 rounded-xl px-4 py-3 backdrop-blur-xl">
    <div class="flex items-center justify-between mb-1.5"><span class="text-xs font-medium">Uploading...</span><span class="text-xs text-zinc-400" x-text="Math.round(upProg)+'%'"></span></div>
    <div class="w-full bg-zinc-700/50 rounded-full h-1"><div class="bg-blue-500 h-1 rounded-full transition-all duration-300" :style="'width:'+upProg+'%'"></div></div>
</div>

<!-- Bottom Nav -->
<nav class="fixed bottom-0 inset-x-0 z-[55] backdrop-blur-xl" style="background:rgba(0,0,0,0.9);border-top:1px solid rgba(63,63,70,0.25)">
    <div class="flex justify-around" style="padding:6px 8px max(8px,env(safe-area-inset-bottom))">
        <button @click="tab='home'" style="flex:1;display:flex;flex-direction:column;align-items:center;gap:2px;padding:4px 0;background:none;border:none;cursor:pointer" :style="tab==='home'?'color:#3B82F6':'color:rgb(113,113,128)'"><i data-lucide="compass" class="w-6 h-6"></i><span class="text-[10px] font-medium">Discover</span></button>
        <button @click="tab='moments'" style="flex:1;display:flex;flex-direction:column;align-items:center;gap:2px;padding:4px 0;background:none;border:none;cursor:pointer" :style="tab==='moments'?'color:#3B82F6':'color:rgb(113,113,128)'"><i data-lucide="layers" class="w-6 h-6"></i><span class="text-[10px] font-medium">Moments</span></button>
        <button @click="tab='people'" style="flex:1;display:flex;flex-direction:column;align-items:center;gap:2px;padding:4px 0;background:none;border:none;cursor:pointer" :style="tab==='people'?'color:#3B82F6':'color:rgb(113,113,128)'"><i data-lucide="users" class="w-6 h-6"></i><span class="text-[10px] font-medium">People</span></button>
        <button @click="tab='settings'" style="flex:1;display:flex;flex-direction:column;align-items:center;gap:2px;padding:4px 0;background:none;border:none;cursor:pointer" :style="tab==='settings'?'color:#3B82F6':'color:rgb(113,113,128)'"><i data-lucide="settings" class="w-6 h-6"></i><span class="text-[10px] font-medium">Settings</span></button>
    </div>
</nav>

</div><!-- .x-data -->

<script>
function app(){return{
    tab:'home',loading:false,
    expIns:null,
    searchQ:'',searchRes:null,
    moments:[],people:[],allPhotos:[],topPhotos:[],insights:[],
    pgOpen:false,pgPerson:null,pgPhotos:[],
    mgOpen:false,mgMoment:null,mgPhotos:[],mgEdit:false,
    tlOpen:false,tlPerson:null,tlPhotos:[],
    lbOpen:false,lbIdx:0,lbPhotos:[],lbDetail:true,lbST:0,lbMenuOpen:false,lbCaptionEdit:false,lbCaption:'',lbMoveShow:false,lbDeleteShow:false,
    // Zoom state (pinch, double-tap, scroll wheel)
    lbZ:{s:1,x:0,y:0,min:1,max:5,panning:false,startX:0,startY:0,pinchDist:0,pinchScale:1,lastTap:0},
    rnOpen:false,rnId:null,rnInput:'',
    addMomentOpen:false,newMomentLabel:'',
    upProg:0,
    toast:{show:false,text:'',type:'success'},
    confirm:{show:false,title:'',message:'',onConfirm:()=>{},okText:'Confirm'},

    async init(){try{const r=await Promise.all([fetch('/api/index'),fetch('/api/moments'),fetch('/api/insights')]);const d=await Promise.all(r.map(x=>x.json()));this.build(d[0],d[1],d[2])}catch(e){this.flash('Load failed','error')}},
    async refreshAll(){this.loading=true;try{const r=await Promise.all([fetch('/api/index'),fetch('/api/moments'),fetch('/api/insights')]);const d=await Promise.all(r.map(x=>x.json()));this.build(d[0],d[1],d[2]);this.flash('Updated')}finally{this.loading=false}},
    build(idx,mom,ins){
        this.people=Object.values(idx?.person_registry||{}).map(p=>({...p,display:p.name||p.id.replace('PERSON_','Person ')})).sort((a,b)=>b.face_count-a.face_count);
        this.allPhotos=(idx.image_catalog||[]).map(p=>{p.person_ids=[...(new Set((p.assignments||[]).filter(a=>a.person_id).map(a=>a.person_id)))];return p});
        this.moments=mom||[];this.insights=ins||[];
        this.topPhotos=[...this.allPhotos.filter(p=>p.quality_score>6)].sort((a,b)=>(b.quality_score||0)-(a.quality_score||0)).slice(0,10);
        this.$nextTick(()=>{lucide.createIcons();this.$refs?.init?.()});
        // Preload avatars
        this.people.forEach(async p=>{if(p.best_face_hash){try{const r=await fetch('/api/face-thumb/'+p.best_face_hash);if(r.ok)p.avatarUrl=URL.createObjectURL(await r.blob())}catch(e){}}});
    },
    // Nav & UI
    flash(t,type='success'){this.toast={show:true,text:t,type};setTimeout(()=>this.toast.show=false,3000)},
    confirmAction(msg,action){
        const confirm=this.confirm;
        confirm.message=msg;confirm.okText=action.startsWith('delete')?'Delete':'OK';
        confirm.onConfirm=async()=>{
            if(action==='regenerateMoments')await this.post('/api/moments/regenerate','Moments regenerated'),await this.refreshAll();
            else if(action==='clearFaces')await navigator.clipboard?.writeText('Cache cleared'),await fetch('/api/moments/regenerate',{method:'POST'}),this.flash('Face cache clear requested');
            else if(action.startsWith('deleteMoment::')){const id=action.split('::')[1];await this.post('/api/moments/delete',{moment_id:id},'Moment deleted');await this.refreshAll();}
            else if(action.startsWith('deletePerson::')){const id=action.split('::')[1];await this.post('/api/people/delete',{person_id:id},'Person deleted');await this.refreshAll();}
            else if(action.startsWith('mergeInit::')){const src=action.split('::')[1];this.mergeSource=src;this.mergePending=true;this.flash('Now tap another person to merge into','success');}
        };
        confirm.show=true;
    },
    mergeSource:null,mergePending:false,
    momentEdit:{show:false,action:'Rename',input:'',target:null},
    editMomentLabel(m){this.momentEdit={show:true,action:'Rename',input:m.label||'',target:m};},
    async doMomentEdit(){
        const m=this.momentEdit.target;if(!m)return;this.momentEdit.show=false;
        await this.post('/api/moments/rename',{moment_id:m.id,new_label:this.momentEdit.input},'Label updated');
        await this.refreshAll();
    },
    showMomentMenu(m){this.moments.forEach(x=>x.__menu=false);m.__menu=true;},
    lightboxOpen(id){this.lbOpen=true;this.lbIdx=id;this.lbPhotos=this.allPhotos;this.lbDetail=true;this.$nextTick(()=>lucide.createIcons());},
    lightboxOpenFromList(idx){this.lbOpen=true;this.lbIdx=idx;this.lbPhotos=this.allPhotos;this.lbDetail=true;this.$nextTick(()=>lucide.createIcons());},
    lbFromPhotos(arr,i){this.lbPhotos=arr;this.lbIdx=i;this.lbOpen=true;this.lbDetail=true;this.pgOpen=false;this.mgOpen=false;this.$nextTick(()=>lucide.createIcons());},
    get lbPhoto(){return this.lbPhotos[this.lbIdx]||null},
    get lbCurUrl(){const p=this.lbPhotos[this.lbIdx]||{};return '/images/'+(p.file_path||'').split('/').pop()},
    get lbPhotoPeople(){return this.lbPhoto?this.people.filter(pp=>(this.lbPhoto.person_ids||[]).includes(pp.id)):[]},
    lbPrev(){if(this.lbIdx>0){this.lbIdx--}},
    lbNext(){if(this.lbIdx<this.lbPhotos.length-1){this.lbIdx++}},
    lbSwipe(e){const d=this.lbST-(e.changedTouches?.[0].clientX||0);Math.abs(d)>50?(d>0?this.lbNext():this.lbPrev()):null},
    imgThumb(i){return'/images/'+((i?.file_path||i?.cover_image||'').split('/').pop())},
    fmtDate(d){try{return new Date(d).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'})}catch(e){return''+d}},
    getMomentDateRange(m){
        if(!m?.member_paths)return'Captured recently';
        try{const ds=m.member_paths.map(fp=>{const ph=this.allPhotos.find(x=>x.file_path===fp);return ph?.analyzed_at?new Date(ph.analyzed_at).getTime():0}).filter(d=>d>0);if(!ds.length)return'Captured recently';const a=new Date(Math.min(...ds)),b=new Date(Math.max(...ds));const f=a.toLocaleDateString('en-US',{month:'short',day:'numeric'}),l=b.toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'});return a.toDateString()===b.toDateString()?f:f+' — '+l}catch(e){return'Captured recently'}
    },
    lbSaveCaption(){
        const p=this.lbPhoto;if(!p)return;
        fetch('/api/photos/caption',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({file_path:p.file_path,caption:this.lbCaption})});
        p.caption=this.lbCaption;this.lbCaptionEdit=false;this.flash('Caption saved');
    },
    lbEditCaption(){this.lbCaptionEdit=true;this.lbCaption=(this.lbPhoto?.caption||'');},
    lbMovePhoto(){
        if(!this.lbPhoto)return;this.lbMoveShow=true;
    },
    async doMovePhoto(targetFolder){
        const p=this.lbPhoto;if(!p)return;
        try{
            const r=await fetch('/api/photos/move',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({file_path:p.file_path,target_folder:targetFolder})});
            if(r.ok||true){
                // Remove from all photo lists and refresh
                this.lbPhotos.splice(this.lbIdx,1);
                if(this.lbIdx>=this.lbPhotos.length)this.lbIdx=Math.max(0,this.lbPhotos.length-1);
                this.lbMoveShow=false;
                this.allPhotos=this.allPhotos.filter(x=>x.file_path!==p.file_path);
                this.pgPhotos=this.pgPhotos.filter(x=>x.file_path!==p.file_path);
                this.mgPhotos=this.mgPhotos.filter(x=>x.file_path!==p.file_path);
                this.tlPhotos=this.tlPhotos.filter(x=>x.file_path!==p.file_path);
                if(this.lbPhotos.length===0){this.lbOpen=false;}
                this.flash('Photo moved');
            }
        }catch(e){this.flash('Move failed','error');this.lbMoveShow=false}
    },
    lbDeletePhoto(){
        if(!this.lbPhoto)return;this.lbDeleteShow=true;
    },
    async doDeletePhoto(){
        const p=this.lbPhoto;if(!p)return;
        try{
            await fetch('/api/photos/delete',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({file_path:p.file_path})});
            this.lbPhotos.splice(this.lbIdx,1);
            if(this.lbIdx>=this.lbPhotos.length)this.lbIdx=Math.max(0,this.lbPhotos.length-1);
            this.lbDeleteShow=false;
            this.allPhotos=this.allPhotos.filter(x=>x.file_path!==p.file_path);
            this.pgPhotos=this.pgPhotos.filter(x=>x.file_path!==p.file_path);
            this.mgPhotos=this.mgPhotos.filter(x=>x.file_path!==p.file_path);
        }catch(e){this.flash('Delete failed','error');this.lbDeleteShow=false}
    },
    // Helpers
    getPhotoIdx(p){return this.allPhotos.findIndex(x=>x.file_path===p.file_path)},
    findPhotoIdx(fp){return this.allPhotos.findIndex(x=>x.file_path===fp)},
    imgThumb(i){return'/images/'+((i?.file_path||i?.cover_image||'').split('/').pop())},
    fmtDate(d){try{return new Date(d).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'})}catch(e){return''+d}},
    getMomentDateRange(m){
        if(!m?.member_paths)return'Captured recently';
        try{const ds=m.member_paths.map(fp=>{const ph=this.allPhotos.find(x=>x.file_path===fp);return ph?.analyzed_at?new Date(ph.analyzed_at).getTime():0}).filter(d=>d>0);if(!ds.length)return'Captured recently';const a=new Date(Math.min(...ds)),b=new Date(Math.max(...ds));const f=a.toLocaleDateString('en-US',{month:'short',day:'numeric'}),l=b.toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'});return a.toDateString()===b.toDateString()?f:f+' — '+l}catch(e){return'Captured recently'}
    },
}}
</script>
</body>
</html>
